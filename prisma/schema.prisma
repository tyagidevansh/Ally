generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id          String     @id @default(uuid())
  userId      String     @unique
  name        String
  imageUrl    String
  email       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  streakStart DateTime?  @db.Timestamp(6)
  streakLast  DateTime?  @db.Timestamp(6)
  bestStreak  Int?       @default(0) @db.SmallInt
  dailyGoal   Int        @default(180) @db.SmallInt
  Journal     Journal[]
  TimerLog    TimerLog[]
  ToDo        ToDo[]
  sentFriendRequests     Friendship[] @relation("SentFriendships")
  receivedFriendRequests Friendship[] @relation("ReceivedFriendships")
  isFocusing  Boolean    @default(false)
  lastTodoReset DateTime @default(now())
}

model TimerLog {
  id        String   @id @default(uuid())
  profileId String
  startTime DateTime
  endTime   DateTime
  duration  Int
  activity  String
  tag       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id])
}

model ToDo {
  profileId   String
  task        String
  priority    Int       @db.SmallInt
  isCompleted Boolean
  id          String    @id @db.Uuid
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  Profile     Profile   @relation(fields: [profileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Journal {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  profileId  String
  entry      String
  mood       Int?     @default(3) @db.SmallInt
  nutrition  Int?     @default(3) @db.SmallInt
  sleep      Int?     @default(3) @db.SmallInt
  Profile    Profile  @relation(fields: [profileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Friendship {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  status    String   @default("PENDING") // PENDING, ACCEPTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user1     Profile  @relation("SentFriendships", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     Profile  @relation("ReceivedFriendships", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
}
